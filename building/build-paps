Ubuntu:
sudo apt -yqq install paps

# 14 characters per inch fits 100 columns onto a letter-sized page.
# There is no syntax highlighting.
paps --paper letter --header --cpi 14  analysis.py > analysis.ps
ps2pdf analysis.ps

