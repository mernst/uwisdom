# For Ubuntu.  But this doesn't work under Docker.
sudo snap install gradle --classic

# Need zip to install SDKMAN, need SDKMAN to install gradle.
# However, SDKMAN requires bash, which prevents testing your software under POSIX sh.
# So this is not appropriate under Docker.
sdk install gradle

